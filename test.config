#
# Example Linux Kernel style .config file
# For testing C/C++ Config Parser extension
#

# Architecture options
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_X86=y
CONFIG_MMU=y

# SMP configuration
CONFIG_SMP=y
CONFIG_SMP_NR_CPUS=8
CONFIG_NR_CPUS=64

# Preemption options
CONFIG_PREEMPT_NONE=y
# CONFIG_PREEMPT_VOLUNTARY is not set
# CONFIG_PREEMPT is not set

# Timer frequency
CONFIG_HZ_250=y
CONFIG_HZ=250

# Memory management
CONFIG_HIGHMEM=y
CONFIG_NUMA=y
CONFIG_NODES_SHIFT=3

# Kernel features
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODVERSIONS=y

# Debug options (disabled)
CONFIG_DEBUG_KERNEL=n
# CONFIG_DEBUG_FS is not set

# String values
CONFIG_LOCALVERSION="-custom"
CONFIG_DEFAULT_HOSTNAME="myhost"

# Numeric values
CONFIG_LOG_BUF_SHIFT=18
CONFIG_PANIC_TIMEOUT=0
CONFIG_DEFAULT_MMAP_MIN_ADDR=65536
